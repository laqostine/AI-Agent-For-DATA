# Google AI
GOOGLE_API_KEY=your_gemini_api_key
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_ENABLED=true

# Google Cloud Storage
GCS_BUCKET_NAME=furnivision-assets
GCS_SIGNED_URL_EXPIRY_HOURS=168

# Firestore
FIRESTORE_DATABASE=furnivision-db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Pipeline Config
MAX_CONCURRENT_IMAGEN_CALLS=8
FRAMES_PER_ROOM=32
MAX_REGENERATION_ATTEMPTS=3
QC_CONSISTENCY_THRESHOLD=0.80
HUMAN_GATE_TIMEOUT_HOURS=48

# App
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","https://furnivision.yourdomain.com"]
SECRET_KEY=generate_a_strong_secret_key_here
